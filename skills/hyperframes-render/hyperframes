#!/bin/sh
# Thin wrapper around the Hyperframes CLI. Passes all args through so
# every subcommand (init, render, dev, build, etc.) is available.
#
# Set HYPERFRAMES_CLI to override the default dist/cli.js location.

CLI="${HYPERFRAMES_CLI:-$HOME/hyperframes/packages/cli/dist/cli.js}"

if [ ! -f "$CLI" ]; then
    echo "Error: hyperframes CLI not found at $CLI" >&2
    exit 127
fi

exec node "$CLI" "$@"
